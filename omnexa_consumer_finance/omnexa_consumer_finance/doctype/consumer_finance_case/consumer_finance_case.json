			"fieldname": "disbursement_date",
			"fieldtype": "Date",
			"label": "Disbursement Date"
		},
		{
			"fieldname": "governance_section",
			"fieldtype": "Section Break",
			"label": "Governance and Controls"
		},
		{
			"fieldname": "restructure_flag",
			"fieldtype": "Check",
			"label": "Restructure Flag",
			"default": "0"
		},
		{
			"fieldname": "restructure_reason",
			"fieldtype": "Small Text",
			"label": "Restructure Reason"
		},
		{
			"fieldname": "decision_reason_codes",
			"fieldtype": "Small Text",
			"label": "Decision Reason Codes"
		},
		{
			"fieldname": "required_controls",
			"fieldtype": "Long Text",
			"label": "Required Controls"
		},
		{
			"fieldname": "case_owner",
			"fieldtype": "Link",
			"label": "Case Owner",
			"options": "User"
		},
		{
			"fieldname": "column_break_omnexa_1",
			"fieldtype": "Column Break"
		},
		{
			"fieldname": "column_break_omnexa_2",
			"fieldtype": "Column Break"
		}
	],
	"index_web_pages_for_search": 1,
	"module": "Omnexa Consumer Finance",
	"name": "Consumer Finance Case",
	"permissions": [
		{
			"role": "System Manager",
			"read": 1,
			"write": 1,
			"create": 1,
			"delete": 1,
			"print": 1,
			"email": 1,
			"export": 1,
			"report": 1,
			"share": 1
		}
	],
	"sort_field": "modified",
	"sort_order": "DESC",
	"track_changes": 1
