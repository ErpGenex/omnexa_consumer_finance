		{
			"fieldname": "dti_ratio",
			"fieldtype": "Percent",
			"label": "DTI Ratio"
		},
		{
			"fieldname": "customer_segment",
			"fieldtype": "Select",
			"label": "Customer Segment",
			"options": "PREMIUM\nHIGH_RISK\nDIGITAL_MASS\nSTANDARD_MASS"
		},
		{
			"fieldname": "collection_stage",
			"fieldtype": "Select",
			"label": "Collection Stage",
			"options": "CURRENT\n30_DPD\n60_DPD\n90_DPD\nLOSS",
