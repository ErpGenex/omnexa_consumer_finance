		},
		{
			"fieldname": "delinquency_days",
			"fieldtype": "Int",
			"label": "Delinquency Days",
			"default": "0"
		},
		{
			"fieldname": "forbearance_flag",
			"fieldtype": "Check",
			"label": "Forbearance Flag",
			"default": "0"
		},
		{
			"fieldname": "lifecycle_stage",
			"fieldtype": "Select",
			"label": "Lifecycle Stage",
			"options": "ORIGINATION\nAPPROVAL\nSERVICING\nWATCHLIST",
			"in_list_view": 1
		},
		{
			"fieldname": "ifrs9_stage",
			"fieldtype": "Select",
			"label": "IFRS9 Stage",
			"options": "STAGE_1\nSTAGE_2\nSTAGE_3",
			"in_list_view": 1
		},
		{
			"fieldname": "decision_status",
			"fieldtype": "Select",
			"label": "Decision Status",
			"options": "APPROVED\nREVIEW\nWATCHLIST\nREJECTED",
			"in_list_view": 1
		},
		{
			"fieldname": "collections_strategy",
			"fieldtype": "Select",
			"label": "Collections Strategy",
			"options": "LIGHT_TOUCH\nPREVENTIVE_OUTREACH\nSTRUCTURED_COLLECTIONS\nINTENSIVE_RECOVERY"
		},
		{
			"fieldname": "risk_score",
			"fieldtype": "Float",
			"label": "Risk Score",
			"precision": "6"
		},
		{
			"fieldname": "pricing_spread",
			"fieldtype": "Percent",
			"label": "Pricing Spread"
		},
		{
			"fieldname": "disbursement_status",
