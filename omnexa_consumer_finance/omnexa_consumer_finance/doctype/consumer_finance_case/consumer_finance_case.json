		{
			"fieldname": "application_channel",
			"fieldtype": "Select",
			"label": "Application Channel",
			"options": "WEB\nMOBILE\nBRANCH",
			"default": "BRANCH"
		},
		{
			"fieldname": "financial_section",
			"fieldtype": "Section Break",
			"label": "Financial and Risk"
		},
		{
			"fieldname": "principal",
			"fieldtype": "Currency",
			"label": "Principal",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "existing_exposure",
			"fieldtype": "Currency",
			"label": "Existing Exposure",
			"default": "0"
		},
		{
			"fieldname": "term_months",
			"fieldtype": "Int",
			"label": "Term (Months)",
			"reqd": 1,
			"in_list_view": 1
		},
		{
			"fieldname": "credit_score",
			"fieldtype": "Int",
			"label": "Credit Score",
			"default": "700"
